# Vercel Postgres connection URL (automatically provided by Vercel in production)
POSTGRES_URL="postgres://username:password@hostname:5432/dbname?sslmode=require"

# Google OAuth Credentials (configured in Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Comma-separated list of developer emails that get access to Admin Dashboard
DEVELOPER_EMAILS="admin@example.com,owner@example.com"

# Secret key for encrypting and signing session cookies
JWT_SECRET="a-very-long-random-string-used-for-signing-cookies"

# Base URL of this deployment. Set to the same domain you registered in Google Cloud Console
# as the OAuth redirect URI (i.e. APP_URL + "/api/auth/callback" = your registered redirect URI).
# Required in production to prevent Host header injection.
# APP_URL="https://your-app.vercel.app"
